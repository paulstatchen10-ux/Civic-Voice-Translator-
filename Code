import { useState } from "react";

const SYSTEM_PROMPT = `You are a civic translator working for Paul Statchen, a civic scientist and systems architect in Santa Cruz, CA.

He speaks for himself AND for those without a voice: unhoused neighbors, working people too busy to comment, immigrants, children, animals, nature, and future generations. He represents: Seabright neighborhood, Santa Cruz City, Santa Cruz County, California, and the United States. His comments are always oriented toward the public good at every level.

Take his raw spoken or written input and produce THREE clean outputs:

1. CITIZEN VERSION: Plain, clear, human English. Readable by any neighbor. Preserves his voice and intent. Fix grammar and readability without changing the meaning or soul of what he said. Conversational but dignified.

2. CIVIC COMMENT VERSION: A structured public comment suitable for submission to any level of government (city, county, state, federal). Use this exact structure:
   - STANDING: Who is speaking and who they represent
   - PROBLEM: Clear problem definition in citizen terms
   - RECOMMENDATION: A clear YES or NO plus one-sentence directive
   - SOLUTION: Specific, actionable solution tied to the issue
   - INTENDED OUTCOME: What success looks like
   - UNINTENDED CONSEQUENCES: (include only if relevant) What to watch for
   This version is plain English but formally structured. Not legalese, but organized for the record.

3. GOVERNMENT/LEGAL VERSION: Formal civic and legal language suitable for submission to a Board of Supervisors, county staff, city council, or government agency in California. Use appropriate California municipal law terminology where relevant (Brown Act, CEQA, resolution, ordinance, MOU, Government Code sections, etc.). Formal tone, structured, citable.

Return ONLY a JSON object with this exact structure, no markdown, no preamble, no backticks:
{
  "topic": "2-4 word topic label",
  "citizen": "the plain english version here",
  "civic": {
    "standing": "who is speaking and who they represent",
    "problem": "clear problem statement",
    "recommendation": "YES or NO — one sentence directive",
    "solution": "specific actionable solution",
    "intended_outcome": "what success looks like",
    "unintended_consequences": "optional — leave empty string if not applicable"
  },
  "legal": "the formal government legal version here"
}`;

const Section = ({ label, color, children, onCopy, copied }) => (
  <div style={{
    background: "#181b22",
    border: `1px solid ${color}33`,
    borderRadius: "4px",
    marginBottom: "1rem",
    overflow: "hidden",
  }}>
    <div style={{
      display: "flex",
      justifyContent: "space-between",
      alignItems: "center",
      padding: "0.6rem 1rem",
      background: `${color}11`,
      borderBottom: `1px solid ${color}33`,
    }}>
      <span style={{
        fontSize: "0.7rem",
        letterSpacing: "0.15em",
        textTransform: "uppercase",
        color: color,
        fontFamily: "monospace",
      }}>{label}</span>
      <button onClick={onCopy} style={{
        background: "transparent",
        border: `1px solid ${color}44`,
        borderRadius: "3px",
        color: copied ? color : "#4a5060",
        fontSize: "0.7rem",
        padding: "0.2rem 0.6rem",
        cursor: "pointer",
        fontFamily: "monospace",
      }}>
        {copied ? "Copied" : "Copy"}
      </button>
    </div>
    <div style={{ padding: "1.25rem" }}>{children}</div>
  </div>
);

const CivicRow = ({ label, value, accent }) => {
  if (!value) return null;
  return (
    <div style={{ marginBottom: "1rem" }}>
      <div style={{
        fontSize: "0.65rem",
        letterSpacing: "0.15em",
        textTransform: "uppercase",
        color: accent,
        fontFamily: "monospace",
        marginBottom: "0.3rem",
      }}>{label}</div>
      <div style={{
        fontSize: "0.95rem",
        lineHeight: 1.7,
        color: "#c8d4c8",
      }}>{value}</div>
    </div>
  );
};

export default function CivicVoiceTranslator() {
  const [input, setInput] = useState("");
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);
  const [copied, setCopied] = useState(null);

  const translate = async () => {
    if (!input.trim()) return;
    setLoading(true);
    setError(null);
    setResult(null);

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 2000,
          system: SYSTEM_PROMPT,
          messages: [{ role: "user", content: input }],
        }),
      });

      const data = await response.json();
      if (data.error) throw new Error(data.error.message);
      const text = data.content?.map(i => i.text || "").join("") || "";
      // Extract JSON robustly — find first { to last }
      const start = text.indexOf("{");
      const end = text.lastIndexOf("}");
      if (start === -1 || end === -1) throw new Error("No JSON found in response");
      const jsonStr = text.slice(start, end + 1);
      const parsed = JSON.parse(jsonStr);
      setResult(parsed);
    } catch (err) {
      setError("Translation failed. Please try again.");
    } finally {
      setLoading(false);
    }
  };

  const copyText = (text, label) => {
    navigator.clipboard.writeText(text);
    setCopied(label);
    setTimeout(() => setCopied(null), 2000);
  };

  const civicAsText = (civic) => {
    if (!civic) return "";
    let out = "";
    if (civic.standing) out += `STANDING:\n${civic.standing}\n\n`;
    if (civic.problem) out += `PROBLEM:\n${civic.problem}\n\n`;
    if (civic.recommendation) out += `RECOMMENDATION:\n${civic.recommendation}\n\n`;
    if (civic.solution) out += `SOLUTION:\n${civic.solution}\n\n`;
    if (civic.intended_outcome) out += `INTENDED OUTCOME:\n${civic.intended_outcome}\n\n`;
    if (civic.unintended_consequences) out += `UNINTENDED CONSEQUENCES:\n${civic.unintended_consequences}`;
    return out.trim();
  };

  const handleKey = (e) => {
    if (e.key === "Enter" && (e.metaKey || e.ctrlKey)) translate();
  };

  return (
    <div style={{
      minHeight: "100vh",
      background: "#0f1117",
      color: "#e8e4dc",
      fontFamily: "'Georgia', serif",
      padding: "2rem 1.5rem",
      maxWidth: "800px",
      margin: "0 auto",
    }}>
      {/* Header */}
      <div style={{ marginBottom: "2.5rem", borderBottom: "1px solid #2a2d36", paddingBottom: "1.5rem" }}>
        <div style={{
          fontSize: "0.7rem",
          letterSpacing: "0.2em",
          color: "#7a8a6a",
          textTransform: "uppercase",
          marginBottom: "0.5rem",
          fontFamily: "monospace",
        }}>
          Santa Cruz County · Civic Voice Project
        </div>
        <h1 style={{
          fontSize: "1.8rem",
          fontWeight: "normal",
          color: "#e8e4dc",
          margin: 0,
          lineHeight: 1.2,
        }}>
          Citizen → Civic → Government
        </h1>
        <p style={{
          fontSize: "0.9rem",
          color: "#7a8a6a",
          marginTop: "0.5rem",
          fontStyle: "italic",
        }}>
          Speak plainly. Get all three voices back.
        </p>
      </div>

      {/* Input */}
      <div style={{ marginBottom: "1.5rem" }}>
        <label style={{
          display: "block",
          fontSize: "0.7rem",
          letterSpacing: "0.15em",
          textTransform: "uppercase",
          color: "#7a8a6a",
          fontFamily: "monospace",
          marginBottom: "0.6rem",
        }}>
          Your words — raw, spoken, or written
        </label>
        <textarea
          value={input}
          onChange={e => setInput(e.target.value)}
          onKeyDown={handleKey}
          placeholder="Say what's on your mind about a civic issue, proposal, or concern. Don't worry about grammar or structure — just say it."
          rows={6}
          style={{
            width: "100%",
            background: "#181b22",
            border: "1px solid #2a2d36",
            borderRadius: "4px",
            color: "#e8e4dc",
            fontFamily: "'Georgia', serif",
            fontSize: "1rem",
            padding: "1rem",
            resize: "vertical",
            outline: "none",
            lineHeight: 1.6,
            boxSizing: "border-box",
          }}
        />
        <div style={{
          display: "flex",
          justifyContent: "space-between",
          alignItems: "center",
          marginTop: "0.75rem",
        }}>
          <span style={{ fontSize: "0.75rem", color: "#4a5060", fontFamily: "monospace" }}>
            ⌘+Enter to translate
          </span>
          <button
            onClick={translate}
            disabled={loading || !input.trim()}
            style={{
              background: loading ? "#2a2d36" : "#4a6741",
              color: loading ? "#4a5060" : "#e8e4dc",
              border: "none",
              borderRadius: "4px",
              padding: "0.6rem 1.5rem",
              fontSize: "0.85rem",
              cursor: loading ? "not-allowed" : "pointer",
              fontFamily: "monospace",
              letterSpacing: "0.1em",
              textTransform: "uppercase",
              transition: "background 0.2s",
            }}
          >
            {loading ? "Translating..." : "Translate"}
          </button>
        </div>
      </div>

      {error && (
        <div style={{
          background: "#2a1a1a",
          border: "1px solid #5a2a2a",
          borderRadius: "4px",
          padding: "1rem",
          color: "#e07070",
          fontSize: "0.9rem",
          marginBottom: "1.5rem",
        }}>
          {error}
        </div>
      )}

      {result && (
        <div>
          <div style={{
            fontSize: "0.7rem",
            letterSpacing: "0.15em",
            textTransform: "uppercase",
            color: "#4a6741",
            fontFamily: "monospace",
            marginBottom: "1.25rem",
          }}>
            Topic: {result.topic}
          </div>

          {/* Citizen */}
          <Section
            label="☀  Citizen Voice — Plain English"
            color="#7ab870"
            onCopy={() => copyText(result.citizen, "citizen")}
            copied={copied === "citizen"}
          >
            <div style={{ fontSize: "1rem", lineHeight: 1.7, color: "#d8d4cc" }}>
              {result.citizen}
            </div>
          </Section>

          {/* Civic Comment */}
          <Section
            label="◈  Civic Comment — Structured for the Record"
            color="#c8a84a"
            onCopy={() => copyText(civicAsText(result.civic), "civic")}
            copied={copied === "civic"}
          >
            <CivicRow label="Standing" value={result.civic?.standing} accent="#c8a84a" />
            <CivicRow label="Problem" value={result.civic?.problem} accent="#c8a84a" />
            <div style={{ marginBottom: "1rem" }}>
              <div style={{
                fontSize: "0.65rem",
                letterSpacing: "0.15em",
                textTransform: "uppercase",
                color: "#c8a84a",
                fontFamily: "monospace",
                marginBottom: "0.3rem",
              }}>Recommendation</div>
              <div style={{
                fontSize: "0.95rem",
                lineHeight: 1.7,
                color: result.civic?.recommendation?.startsWith("YES") ? "#7ab870" : "#e07070",
                fontWeight: "bold",
              }}>
                {result.civic?.recommendation}
              </div>
            </div>
            <CivicRow label="Solution" value={result.civic?.solution} accent="#c8a84a" />
            <CivicRow label="Intended Outcome" value={result.civic?.intended_outcome} accent="#c8a84a" />
            {result.civic?.unintended_consequences && (
              <CivicRow label="Unintended Consequences" value={result.civic?.unintended_consequences} accent="#a87a4a" />
            )}
          </Section>

          {/* Legal */}
          <Section
            label="⚖  Government / Legal Language"
            color="#7a8ab8"
            onCopy={() => copyText(result.legal, "legal")}
            copied={copied === "legal"}
          >
            <div style={{
              fontSize: "0.95rem",
              lineHeight: 1.8,
              color: "#c8ccd8",
              fontFamily: "monospace",
            }}>
              {result.legal}
            </div>
          </Section>

          {/* Copy All */}
          <button
            onClick={() => copyText(
              `CITIZEN VOICE:\n${result.citizen}\n\n---\n\nCIVIC COMMENT:\n${civicAsText(result.civic)}\n\n---\n\nGOVERNMENT/LEGAL:\n${result.legal}`,
              "all"
            )}
            style={{
              marginTop: "0.5rem",
              width: "100%",
              background: "transparent",
              border: "1px solid #2a2d36",
              borderRadius: "4px",
              color: copied === "all" ? "#e8e4dc" : "#4a5060",
              fontSize: "0.75rem",
              padding: "0.6rem",
              cursor: "pointer",
              fontFamily: "monospace",
              letterSpacing: "0.1em",
              textTransform: "uppercase",
            }}
          >
            {copied === "all" ? "✓ All Three Copied" : "Copy All Three Versions"}
          </button>
        </div>
      )}

      <div style={{
        marginTop: "3rem",
        paddingTop: "1rem",
        borderTop: "1px solid #1a1d24",
        fontSize: "0.7rem",
        color: "#2a2d36",
        fontFamily: "monospace",
        textAlign: "center",
      }}>
        Civic Voice Project · Santa Cruz County · Paul Statchen
      </div>
    </div>
  );
}
